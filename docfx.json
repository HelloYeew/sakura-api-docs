{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [{ 
        "src": "../sakura", 
        "files": ["Sakura.Framework/*.csproj"] 
      }],
      "dest": "api/core",
      "properties": {
        "TargetFramework": "net9.0"
      }
    },
    {
      "src": [{ 
        "src": "../sakura-imaging", 
        "files": ["Sakura.Framework.Imaging/*.csproj"] 
      }],
      "dest": "api/imaging",
      "properties": {
        "TargetFramework": "net9.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Sakura Framework",
      "_appTitle": "Sakura Framework",
      "_nestedNamespaces": true,
      "_enableSearch": true,
      "pdf": false
    }
  }
}